<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- All connections route through Orbot (Tor SOCKS5). No clearnet traffic permitted. -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <!-- No trust anchors: .onion connections are authenticated by the onion address itself. -->
        </trust-anchors>
    </base-config>
</network-security-config>
